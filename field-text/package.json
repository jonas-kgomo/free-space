{
  "name": "distance-field",
  "version": "0.1.1",
  "description": "High-performance GPU-accelerated text layout and rendering library",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:lib && npm run build:demos",
    "build:lib": "vite build --config vite.config.lib.ts && tsc --emitDeclarationOnly",
    "build:demos": "vite build",
    "preview": "vite preview",
    "bench": "vite bench"
  },
  "keywords": [
    "text",
    "layout",
    "rendering",
    "canvas",
    "webgl",
    "sdf",
    "gpu"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "@types/three": "^0.162.0",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "three": "^0.162.0"
  }
}
